#!/usr/bin/env python3
"""helm — stamp the captain/firstmate/crew workflow kit into a target repo.

Commands:
  helm init <repo> [--preset <name|path>] [--force]   install the kit
  helm update <repo>                                  re-stamp unmodified kit files
  helm list                                           show registered projects

Stdlib-only on purpose: the kit is JSON presets + {{placeholder}} substitution +
a JSON merge into .claude/settings.json — none of which needs a dependency, and
the same rendering pipeline drives both init and update.
"""
from __future__ import annotations

import argparse
import hashlib
import json
import re
import sys
from datetime import date, datetime, timezone
from pathlib import Path

HELM_ROOT = Path(__file__).resolve().parent
KIT = HELM_ROOT / "kit"
REGISTRY = Path.home() / ".helm" / "projects.json"
KIT_VERSION = json.loads((KIT / "kit.json").read_text())["version"]
MANIFEST_NAME = ".helm-kit.json"
MARK_BEGIN, MARK_END = "<!-- helm:begin -->", "<!-- helm:end -->"

# Soft cap on concurrent crew subagents the firstmate spawns for a project,
# absent an explicit "max_parallel_agents" in the preset or a --max-parallel
# override. Worktrees are isolated and claims are atomic, so nothing breaks
# above this — it exists to bound cost/context/rate-limit blast radius, not
# to enforce correctness.
DEFAULT_MAX_PARALLEL = 3

# Scripts copied byte-for-byte — they self-locate via `git rev-parse --git-common-dir`,
# so they work in any repo without templating.
VERBATIM_SCRIPTS = [
    "_lib.sh", "claim.sh", "submit.sh", "approve.sh", "auto-approve.sh",
    "reject.sh", "unclaim.sh", "next.sh", "board.sh",
]


def die(msg: str) -> None:
    print(f"ERROR: {msg}", file=sys.stderr)
    sys.exit(1)


def sha(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def render(text: str, mapping: dict[str, str]) -> str:
    for key, val in mapping.items():
        text = text.replace("{{" + key + "}}", val)
    leftover = re.findall(r"\{\{[a-z_]+\}\}", text)
    if leftover:
        die(f"unrendered placeholders {sorted(set(leftover))} — preset is missing keys")
    return text


def load_preset(spec: str) -> dict:
    p = Path(spec)
    if not (p.is_file() and p.suffix == ".json"):
        p = KIT / "presets" / f"{spec}.json"
    if not p.is_file():
        names = sorted(f.stem for f in (KIT / "presets").glob("*.json"))
        die(f"preset '{spec}' not found (available: {', '.join(names)}, or pass a JSON path)")
    return json.loads(p.read_text())


def build_mapping(preset: dict) -> dict[str, str]:
    personas = preset["personas"]
    return {
        "project_name": preset["project_name"],
        "default_area": preset["default_area"],
        "today": date.today().isoformat(),
        "areas_pipe": " | ".join(preset["areas"]),
        "areas_table": " ".join(f"`{a}`" for a in preset["areas"]),
        "crew_names": ", ".join(p["name"] for p in personas),
        "personas_bullets": "\n".join(
            f"- **{p['name']}** — claims `--area {p['area']}` tasks: {p['stack'].split('.')[0]}."
            for p in personas
        ),
        "safety_context": preset["safety_context"],
        "safety_rules": "\n".join(preset["safety_rules"]),
        "arch_notes": "\n".join(preset["arch_notes"]),
        "max_parallel_agents": str(preset.get("max_parallel_agents", DEFAULT_MAX_PARALLEL)),
    }


def build_outputs(preset: dict) -> dict[str, tuple[bytes, bool]]:
    """All kit files as {repo-relative path: (content, executable)}.

    One pipeline for init AND update, so update can diff current files
    against what the kit would produce today.
    """
    m = build_mapping(preset)
    out: dict[str, tuple[bytes, bool]] = {}

    for name in VERBATIM_SCRIPTS:
        out[f"tasks/{name}"] = ((KIT / "tasks" / name).read_bytes(), True)
    out["tasks/_TEMPLATE.md"] = (
        render((KIT / "tasks/_TEMPLATE.md.tmpl").read_text(), m).encode(), False)
    out["tasks/README.md"] = (
        render((KIT / "tasks/README.md.tmpl").read_text(), m).encode(), False)

    crew_tmpl = (KIT / "claude/agents/crew-dev.md.tmpl").read_text()
    for p in preset["personas"]:
        pm = {**m, "name": p["name"], "area": p["area"], "stack": p["stack"]}
        out[f".claude/agents/{p['name']}.md"] = (render(crew_tmpl, pm).encode(), False)
    for role in ("reviewer", "researcher"):
        out[f".claude/agents/{role}.md"] = (
            render((KIT / f"claude/agents/{role}.md.tmpl").read_text(), m).encode(), False)

    out[".claude/hooks/gate-on-submit.sh"] = (
        (KIT / "claude/hooks/gate-on-submit.sh").read_bytes(), True)
    out[".claude/skills/no-mistakes/SKILL.md"] = (
        render((KIT / "claude/skills/no-mistakes/SKILL.md.tmpl").read_text(), m).encode(), False)
    return out


def write_file(repo: Path, rel: str, content: bytes, executable: bool) -> None:
    dest = repo / rel
    dest.parent.mkdir(parents=True, exist_ok=True)
    dest.write_bytes(content)
    if executable:
        dest.chmod(dest.stat().st_mode | 0o111)


def upsert_marker_block(path: Path, block: str) -> str:
    """Insert or replace the helm-managed block in CLAUDE.md / AGENTS.md."""
    wrapped = f"{MARK_BEGIN}\n{block.rstrip()}\n{MARK_END}\n"
    if path.exists():
        text = path.read_text()
        if MARK_BEGIN in text and MARK_END in text:
            pre, rest = text.split(MARK_BEGIN, 1)
            _, post = rest.split(MARK_END, 1)
            path.write_text(pre + wrapped + post.lstrip("\n"))
            return "updated"
        path.write_text(text.rstrip("\n") + "\n\n" + wrapped)
        return "appended"
    path.write_text(wrapped)
    return "created"


def merge_settings_hook(repo: Path) -> str:
    """Add the gate hook to .claude/settings.json without clobbering existing config."""
    snippet = json.loads((KIT / "claude/settings-snippet.json").read_text())
    entry = snippet["hooks"]["PostToolUse"][0]
    path = repo / ".claude" / "settings.json"
    settings = json.loads(path.read_text()) if path.exists() else {}
    post = settings.setdefault("hooks", {}).setdefault("PostToolUse", [])
    for e in post:
        for h in e.get("hooks", []):
            if "gate-on-submit.sh" in h.get("command", ""):
                return "already present"
    post.append(entry)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(settings, indent=2) + "\n")
    return "installed"


def register(repo: Path) -> str:
    REGISTRY.parent.mkdir(parents=True, exist_ok=True)
    reg = json.loads(REGISTRY.read_text()) if REGISTRY.exists() else {"projects": [], "active": None}
    pid = repo.name.lower()
    if not any(p["id"] == pid for p in reg["projects"]):
        reg["projects"].append({"id": pid, "path": str(repo)})
    reg["active"] = reg["active"] or pid
    REGISTRY.write_text(json.dumps(reg, indent=2) + "\n")
    return pid


def resolve_repo(arg: str) -> Path:
    repo = Path(arg).expanduser().resolve()
    if not (repo / ".git").exists():
        die(f"{repo} is not a git repository (run `git init` there first)")
    return repo


def cmd_init(args: argparse.Namespace) -> None:
    repo = resolve_repo(args.repo)
    if (repo / "tasks" / "_lib.sh").exists() and not args.force:
        die(f"{repo}/tasks already has a board — use `helm update` or --force")

    preset_spec = args.preset or (repo.name.lower()
                                  if (KIT / "presets" / f"{repo.name.lower()}.json").exists()
                                  else "default")
    preset = load_preset(preset_spec)
    if args.max_parallel is not None:
        preset["max_parallel_agents"] = args.max_parallel
    outputs = build_outputs(preset)

    for rel, (content, execu) in outputs.items():
        write_file(repo, rel, content, execu)
    for extra in ("tasks/phase-0", "tasks/phase-1", "docs/research", "docs/contracts"):
        (repo / extra).mkdir(parents=True, exist_ok=True)
        (repo / extra / ".gitkeep").touch()

    block = render((KIT / "snippets/CLAUDE-workflow.md.tmpl").read_text(), build_mapping(preset))
    claude_md = upsert_marker_block(repo / "CLAUDE.md", block)
    agents_md = upsert_marker_block(repo / "AGENTS.md", block)
    hook = merge_settings_hook(repo)

    manifest = {
        "kit_version": KIT_VERSION,
        "installed_at": datetime.now(timezone.utc).isoformat(timespec="seconds"),
        "preset": preset,  # inlined so `helm update` re-renders identically
        "files": {rel: sha(content) for rel, (content, _) in outputs.items()},
    }
    (repo / MANIFEST_NAME).write_text(json.dumps(manifest, indent=2) + "\n")
    pid = register(repo)

    print(f"Installed Helm kit v{KIT_VERSION} ({preset['project_name']}) into {repo}")
    print(f"  crew: {', '.join(p['name'] for p in preset['personas'])} + researcher + reviewer")
    print(f"  CLAUDE.md {claude_md}, AGENTS.md {agents_md}, settings.json hook {hook}")
    print(f"  registered as '{pid}' in {REGISTRY}")
    old_researcher = repo / ".agents" / "agents" / "researcher.md"
    if old_researcher.exists():
        print(f"  NOTE: {old_researcher} predates the kit — the kit's researcher now lives at"
              f" .claude/agents/researcher.md; retire the old copy when convenient.")
    print("\nNext steps:")
    print("  1. git add tasks .claude docs CLAUDE.md AGENTS.md .helm-kit.json && git commit")
    print("  2. copy tasks/_TEMPLATE.md to tasks/phase-0/T-001.md and fill it in")
    print("  3. ./tasks/board.sh — or ask the firstmate (main Claude session) to run the board")


def cmd_update(args: argparse.Namespace) -> None:
    repo = resolve_repo(args.repo)
    mpath = repo / MANIFEST_NAME
    if not mpath.exists():
        die(f"no {MANIFEST_NAME} in {repo} — run `helm init` first")
    manifest = json.loads(mpath.read_text())
    outputs = build_outputs(manifest["preset"])

    updated, skipped, added = [], [], []
    for rel, (content, execu) in outputs.items():
        dest = repo / rel
        if not dest.exists():
            write_file(repo, rel, content, execu); added.append(rel)
        elif sha(dest.read_bytes()) == manifest["files"].get(rel):
            if sha(content) != manifest["files"].get(rel):
                write_file(repo, rel, content, execu); updated.append(rel)
        else:
            skipped.append(rel)  # locally modified — never clobber

    block = render((KIT / "snippets/CLAUDE-workflow.md.tmpl").read_text(),
                   build_mapping(manifest["preset"]))
    for name in ("CLAUDE.md", "AGENTS.md"):
        upsert_marker_block(repo / name, block)

    manifest["kit_version"] = KIT_VERSION
    manifest["files"] = {rel: sha(c) for rel, (c, _) in outputs.items()}
    mpath.write_text(json.dumps(manifest, indent=2) + "\n")

    print(f"Updated to kit v{KIT_VERSION}: {len(updated)} refreshed, {len(added)} added, "
          f"{len(skipped)} locally-modified skipped")
    for rel in skipped:
        print(f"  skipped (edit yours vs kit manually): {rel}")


def cmd_list(_args: argparse.Namespace) -> None:
    if not REGISTRY.exists():
        print("no projects registered — run `helm init <repo>`"); return
    reg = json.loads(REGISTRY.read_text())
    for p in reg["projects"]:
        mark = "*" if p["id"] == reg.get("active") else " "
        print(f"{mark} {p['id']:<12} {p['path']}")


def main() -> None:
    ap = argparse.ArgumentParser(prog="helm", description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = ap.add_subparsers(dest="cmd", required=True)
    p_init = sub.add_parser("init", help="install the kit into a repo")
    p_init.add_argument("repo")
    p_init.add_argument("--preset", help="preset name (kit/presets/*.json) or a JSON path")
    p_init.add_argument("--max-parallel", type=int, dest="max_parallel",
                        help=f"cap on concurrent crew subagents the firstmate spawns "
                             f"(default: preset's max_parallel_agents, or {DEFAULT_MAX_PARALLEL})")
    p_init.add_argument("--force", action="store_true")
    p_init.set_defaults(fn=cmd_init)
    p_up = sub.add_parser("update", help="re-stamp unmodified kit files in a repo")
    p_up.add_argument("repo")
    p_up.set_defaults(fn=cmd_update)
    sub.add_parser("list", help="show registered projects").set_defaults(fn=cmd_list)
    args = ap.parse_args()
    args.fn(args)


if __name__ == "__main__":
    main()
